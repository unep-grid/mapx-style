# Build output
dist/
tmp/

# Test output
coverage/
test-results/
playwright-report/

# JS deps
node_modules/

# agents
.claude

# Python env
.venv/
__pycache__/
*.py[cod]
*.egg-info/

# Credentials
.env
.env.*.local
.env.local
.env.development.local

# Exclude generated env types file
env.d.ts

# Large geo files (use scripts/s3/ to upload these)
*.gpkg
*.geojson
*.tif
*.tiff
*.geotiff
*.mbtiles
*.pmtiles

# Generated S3 inventory snapshots
data/catalog.json
data/s3_catalog*.json

# Rust build output
target/

# Font TTF sources (download with: uv run scripts/download_fonts.py)
data/fonts/files/

# Generated PBF glyphs (built from TTFs, uploaded to S3 — not committed)
*.pbf

# Generated sprite sheets (built by build_sprites.py, uploaded to S3 — not committed)
packages/theme-core/assets/sprites/generated/
# Pattern SVGs (generated by npm run build:patterns — not committed)
packages/theme-core/assets/sprites/patterns/

# Editor swap / backup files
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db
