{
  "$schema": "https://unpkg.com/release-it/schema/release-it.json",
  "git": {
    "tagName": "v${version}",
    "tagAnnotation": "Release v${version}",
    "commitMessage": "chore: release v${version}",
    "requireBranch": "main",
    "commit": true,
    "tag": true,
    "push": true,
    "pushArgs": ["--follow-tags"],
    "commitFiles": [
      "package.json",
      "package-lock.json",
      "packages/theme-core/package.json",
      "packages/theme-core/dist",
      "CHANGELOG.md"
    ]
  },
  "github": {
    "release": false
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "after:version:bump": [
      "node scripts/release_sync_version.cjs",
      "npm run build:lib -w packages/theme-core"
    ]
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "conventionalcommits",
      "infile": "CHANGELOG.md"
    }
  }
}
