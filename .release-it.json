{
  "$schema": "https://unpkg.com/release-it/schema/release-it.json",
  "packageFiles": ["packages/theme-core/package.json"],
  "bumpFiles": ["packages/theme-core/package.json"],
  "git": {
    "tagName": "v${version}",
    "commitMessage": "chore: release v${version}",
    "requireBranch": "main",
    "commitFiles": [
      "packages/theme-core/package.json",
      "packages/theme-core/dist",
      "CHANGELOG.md"
    ]
  },
  "github": {
    "release": true,
    "releaseName": "v${version}"
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "before:git:release": "npm run build:lib -w packages/theme-core"
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "conventionalcommits",
      "infile": "CHANGELOG.md"
    }
  }
}
