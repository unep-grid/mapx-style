{
  "name": "@unep-grid/mapx-style",
  "version": "0.4.2",
  "type": "module",
  "description": "MapX style engine: HCP S3 auth, PMTiles protocol, DEM/terrain, themes, and MapLibre layer resolvers",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "default": "./dist/mapx-style.umd.js"
    }
  },
  "main": "./dist/mapx-style.umd.js",
  "module": "./src/index.js",
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build:lib": "vite build --config vite.config.lib.js"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "chroma-js": "^3.0.0",
    "pmtiles": "^4.0.0"
  },
  "peerDependencies": {
    "@fontsource/libre-baskerville": "^5",
    "@fontsource/noto-sans": "^5",
    "@fontsource/noto-sans-arabic": "^5",
    "@fontsource/noto-sans-armenian": "^5",
    "@fontsource/noto-sans-bengali": "^5",
    "@fontsource/noto-sans-mono": "^5",
    "@fontsource/noto-sans-sc": "^5",
    "@fontsource/roboto": "^5",
    "@fontsource/titillium-web": "^5",
    "@fontsource/varela-round": "^5"
  }
}
