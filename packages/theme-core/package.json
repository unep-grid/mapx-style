{
  "name": "@unep-grid/mapx-style",
  "version": "0.8.7",
  "type": "module",
  "private": false,
  "description": "MapX style engine: HCP S3 auth, PMTiles protocol, DEM/terrain, themes, and MapLibre layer resolvers",
  "repository": {
    "type": "git",
    "url": "https://github.com/unep-grid/mapx-style.git",
    "directory": "packages/theme-core"
  },
  "exports": {
    ".": {
      "import": "./dist/mapx-style.esm.js",
      "default": "./dist/mapx-style.umd.js"
    }
  },
  "main": "./dist/mapx-style.umd.js",
  "module": "./dist/mapx-style.esm.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build:lib": "vite build --config vite.config.lib.js",
    "prepublishOnly": "node -e \"if (process.env.GITHUB_ACTIONS !== 'true') { console.error('Publishing @unep-grid/mapx-style is only allowed from GitHub Actions trusted publishing.'); process.exit(1); }\""
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "dependencies": {
    "chroma-js": "^3.0.0",
    "pmtiles": "^4.0.0"
  },
  "peerDependencies": {
    "@fontsource/libre-baskerville": "^5",
    "@fontsource/noto-sans": "^5",
    "@fontsource/noto-sans-arabic": "^5",
    "@fontsource/noto-sans-armenian": "^5",
    "@fontsource/noto-sans-bengali": "^5",
    "@fontsource/noto-sans-mono": "^5",
    "@fontsource/noto-sans-sc": "^5",
    "@fontsource/roboto": "^5",
    "@fontsource/titillium-web": "^5",
    "@fontsource/varela-round": "^5"
  }
}
