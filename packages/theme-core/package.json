{
  "name": "@unep-grid/mapx-style",
  "version": "0.3.0",
  "type": "module",
  "description": "MapX style engine: HCP S3 auth, PMTiles protocol, DEM/terrain, themes, and MapLibre layer resolvers",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "default": "./dist/mapx-style.umd.js"
    }
  },
  "main": "./dist/mapx-style.umd.js",
  "module": "./src/index.js",
  "files": [
    "data/fonts",
    "src",
    "dist"
  ],
  "scripts": {
    "build:lib": "vite build --config vite.config.lib.js"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "chroma-js": "^3.0.0",
    "pmtiles": "^4.0.0"
  }
}
