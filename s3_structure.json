{
  "$comment": "MapX S3 bucket path conventions — source of truth for tooling",
  "bucket": "mapx",
  "paths": {
    "layers": {
      "prefix": "layers/",
      "naming": "{layer-name}__{version}.pmtiles",
      "pattern": "^layers/[a-z][a-z0-9_]*__v[0-9]+\\.pmtiles$",
      "examples": [
        "layers/un_borders_labels_2020__v0.pmtiles",
        "layers/un_borders_polygon_2020__v0.pmtiles",
        "layers/un_borders_polygon_2020__v2.pmtiles",
        "layers/un_borders_lines_2020__v2.pmtiles",
        "layers/elevation_30m_world__v0.pmtiles",
        "layers/esri_world_sat__v0.pmtiles"
      ]
    },
    "style": {
      "prefix": "style/{env}/",
      "envs": ["prod", "staging","dev"],
      "assets": "style/{env}/assets/",
      "sprites": "style/{env}/assets/sprites/",
      "sprite_index": "style/{env}/assets/sprites/sprite-index.json",
      "glyphs": "style/{env}/assets/glyphs/",
      "examples": [
        "style/prod/main_v0.json",
        "style/prod/main_v1.json",
        "style/staging/main_v0.json",
        "style/staging/assets/glyphs/Open Sans Regular/0-255.pbf",
        "style/prod/assets/sprites/default.png"
      ]
    },
    "data": {
      "prefix": "data/{context}/{user_id}/",
      "contexts": ["prod", "staging", "training", "wesr"],
      "tmp": "data/{context}/{user_id}/tmp/",
      "ttl": {
        "upload": "24h",
        "export": "6h"
      }
    },
    "masks": {
      "prefix": "masks/",
      "naming": "{mask-name}__v{N}.geojson",
      "pattern": "^masks/[a-z][a-z0-9_]*__v[0-9]+\\.geojson$",
      "examples": [
        "masks/un_2020_countries_mask__v0.geojson"
      ]
    }
  }
}
