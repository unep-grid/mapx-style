# This env file uses @env-spec - see https://varlock.dev/env-spec for more info
#
# @plugin(@varlock/proton-pass-plugin)
# @defaultRequired=infer @defaultSensitive=false
# @generateTypes(lang=ts, path=env.d.ts)
# @initProtonPass()
# ----------

# HCP S3 credentials — fetched from the system password store at runtime.
# Encoded by s3_client.py: access_key = base64(S3_USER), secret_key = md5(S3_KEY).
# @type=string
S3_KEY=protonPass(pass://unep-grid/mapx.unepgrid.s3.unige.ch/password)
# @type=string
S3_USER=protonPass(pass://unep-grid/mapx.unepgrid.s3.unige.ch/username)

# S3 bucket and endpoint for all uploads (Python scripts).
S3_BUCKET=mapx
# @type=url
S3_ENDPOINT=https://mapx.unepgrid.s3.unige.ch/

# Public base URL used by Python scripts to construct catalog entries and sprite-index URLs.
# Format: {S3_ENDPOINT}{S3_BUCKET}  (no trailing slash added by scripts)
# @type=url
S3_PUBLIC_BASE_URL=https://mapx.unepgrid.s3.unige.ch/mapx

# HCP-specific: credential encoding mode used by s3_client.py.
S3_AUTH_MODE=hcp

# Header injected by range_test.py on every public S3 request.
# HCP requires this on public objects — without it the server redirects to the REST API
# instead of serving the object (no error, just a wrong response).
S3_PUBLIC_REQUEST_HEADERS={"Authorization":"AWS all_users:"}

# Base URL the demo app (browser) uses to load MapX assets: tiles, glyphs, sprites.
# Usually matches S3_PUBLIC_BASE_URL, but can differ to point the demo at a mirror,
# a staging bucket, or a CDN without changing where Python scripts upload.
# Leave empty to disable remote asset loading in the demo.
# @type=url
VITE_MAPX_ASSET_BASE_URL=https://mapx.unepgrid.s3.unige.ch/mapx

# JSON object of HTTP headers sent by the demo app with every asset request.
# Required for HCP public objects — same reason as S3_PUBLIC_REQUEST_HEADERS above.
# Example: {"Authorization":"AWS all_users:"}
VITE_MAPX_ASSET_REQUEST_HEADERS={"Authorization":"AWS all_users:"}

# API key for the Protomaps CDN — used by build_basemap.py to download the basemap PMTiles.
PROTOMAPS_KEY=protonPass(pass://unep-grid/mapx.protomaps.com/secret)
